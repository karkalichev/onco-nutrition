# Copy to .env and fill in your key
ANTHROPIC_API_KEY=sk-ant-...

# Optional — default is claude-sonnet-4-5 (do NOT use claude-sonnet-4-20250514 — 404)
# ANTHROPIC_MODEL=claude-sonnet-4-5
# ANTHROPIC_MODEL=claude-opus-4-5
# ANTHROPIC_MAX_TOKENS=4096   # BG JSON answers need headroom; raise if truncated

# Retrieval: auto (vector if chroma index exists) | vector | keyword
# RETRIEVAL=auto

# Optional LangSmith (LangChain tracing) — not required for MVP
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=onco-nutrition
